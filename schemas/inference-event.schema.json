{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telperia.org/schemas/inference-event.schema.json",
  "title": "Telperia Inference Event",
  "description": "One non-content inference event. Prompt and response text are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "start_time",
    "end_time",
    "latency_ms",
    "model_id",
    "input_tokens",
    "output_tokens",
    "tokens_per_second",
    "success",
    "error_category"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "tokens_per_second": {
      "type": "number",
      "minimum": 0
    },
    "success": {
      "type": "boolean"
    },
    "error_category": {
      "type": ["string", "null"]
    }
  }
}
