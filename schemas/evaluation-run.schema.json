{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telperia.org/schemas/evaluation-run.schema.json",
  "title": "Telperia Evaluation Run",
  "description": "Result package for one local Telperia evaluation run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "timestamp",
    "model",
    "runtime",
    "hardware",
    "methodology",
    "evaluation",
    "energy",
    "performance",
    "verification"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "revision", "quantization"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "quantization": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "engine_version"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["ollama"]
        },
        "engine_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gpu", "gpu_count", "driver", "cuda", "system_ram_gb"],
      "properties": {
        "gpu": {
          "type": "string",
          "minLength": 1
        },
        "gpu_count": {
          "type": "integer",
          "minimum": 1
        },
        "driver": {
          "type": "string",
          "minLength": 1
        },
        "cuda": {
          "type": "string",
          "minLength": 1
        },
        "system_ram_gb": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "documents"],
      "properties": {
        "version": {
          "const": "0.1"
        },
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suite", "completed_tasks", "total_tasks", "scores"],
      "properties": {
        "suite": {
          "type": "string",
          "minLength": 1
        },
        "completed_tasks": {
          "type": "integer",
          "minimum": 0
        },
        "total_tasks": {
          "type": "integer",
          "minimum": 0
        },
        "completion_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "scores": {
          "type": "object",
          "additionalProperties": true
        },
        "raw_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["task_id", "category", "success"],
            "properties": {
              "task_id": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "type": "string",
                "minLength": 1
              },
              "score": {
                "type": "number"
              },
              "success": {
                "type": "boolean"
              },
              "error_category": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    },
    "energy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gpu_energy_wh",
        "sampling_interval_ms",
        "average_power_w",
        "peak_power_w"
      ],
      "properties": {
        "gpu_energy_wh": {
          "type": "number",
          "minimum": 0
        },
        "sampling_interval_ms": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "average_power_w": {
          "type": "number",
          "minimum": 0
        },
        "peak_power_w": {
          "type": "number",
          "minimum": 0
        },
        "raw_power_samples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["timestamp", "power_w"],
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "power_w": {
                "type": "number",
                "minimum": 0
              },
              "interval_s": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          }
        }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "tokens_per_second",
        "error_count"
      ],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_per_second": {
          "type": "number",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "runner_version"],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "runner_version": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
